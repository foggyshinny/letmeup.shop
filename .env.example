# ─────────────────────────────────────────────────────────────────────────
# letmeup.shop 환경변수 예시
# 실제 값은 .env.local (로컬) 또는 Amplify 환경변수(배포)에 넣으세요.
# .env.local 은 git에 커밋되지 않습니다.
# ─────────────────────────────────────────────────────────────────────────

# 사이트 base URL (PG 콜백 리턴 URL 구성에 사용)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── KSNET PG (값이 비어 있으면 자동으로 모의 결제 모드로 동작) ──
# 가맹점 ID
KSNET_MID=
# 가맹점 라이선스/서명 키
KSNET_MERCHANT_KEY=
# 승인 API 베이스 URL (예: https://api.ksnet.co.kr)
KSNET_API_BASE=
# 결제창 호출 URL
KSNET_PAY_URL=

# ── 비즈뿌리오(Bizppurio) 문자 발송 (비어 있으면 모의 발송: 콘솔 로그만) ──
# 비즈뿌리오 계정 ID
BIZPPURIO_USER=
# 비즈뿌리오 계정 비밀번호
BIZPPURIO_PASSWORD=
# 사전 등록된 발신번호 (예: 16884264)
BIZPPURIO_FROM=
# API 베이스 URL (기본값 사용 시 비워둬도 됨)
BIZPPURIO_API_BASE=https://api.bizppurio.com

# ── 인증/세션 ──
# 세션·관리자 토큰 서명 키 (운영에서는 반드시 임의의 긴 문자열로 설정)
AUTH_SECRET=

# ── 관리자 (아이디/비밀번호 + Authy(TOTP) 2차 인증) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Authy/OTP 앱에 등록한 base32 시크릿 (미설정 시 데모 시크릿으로 동작)
ADMIN_TOTP_SECRET=
